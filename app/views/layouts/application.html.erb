<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Symulator Grup Fokusowych" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Symulator Grup Fokusowych">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 text-gray-900">
    <% if user_signed_in? %>
      <nav class="bg-white border-b border-gray-200 shadow-sm">
        <div class="container mx-auto px-5 py-3 flex items-center justify-between">
          <div class="flex gap-6">
            <%= link_to "Sesje", focus_groups_path, class: "font-semibold text-indigo-700 hover:underline" %>
            <%= link_to "Produkty", products_path, class: "text-gray-700 hover:underline" %>
          </div>
          <div class="flex items-center gap-4 text-sm">
            <span class="text-gray-500"><%= current_user.email %></span>
            <%= button_to "Wyloguj", destroy_user_session_path, method: :delete,
                  class: "text-red-600 hover:underline bg-transparent border-0 p-0 cursor-pointer" %>
          </div>
        </div>
      </nav>
    <% end %>

    <main class="container mx-auto mt-8 px-5">
      <% if notice %>
        <div class="mb-4 px-4 py-2 bg-green-100 border border-green-300 text-green-900 rounded"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="mb-4 px-4 py-2 bg-red-100 border border-red-300 text-red-900 rounded"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
