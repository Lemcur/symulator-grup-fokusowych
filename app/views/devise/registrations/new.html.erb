<% content_for :title, "Rejestracja" %>

<div class="max-w-md mx-auto bg-white p-8 rounded shadow border border-gray-200 mt-12">
  <h1 class="text-2xl font-bold mb-6">Rejestracja</h1>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, class: "block font-semibold mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full px-3 py-2 border border-gray-300 rounded" %>
    </div>

    <div>
      <%= f.label :password, class: "block font-semibold mb-1" %>
      <%= f.password_field :password, autocomplete: "new-password",
            class: "w-full px-3 py-2 border border-gray-300 rounded" %>
      <% if @minimum_password_length %>
        <p class="text-xs text-gray-500 mt-1">Minimum <%= @minimum_password_length %> znaków.</p>
      <% end %>
    </div>

    <div>
      <%= f.label :password_confirmation, class: "block font-semibold mb-1" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: "w-full px-3 py-2 border border-gray-300 rounded" %>
    </div>

    <div class="pt-2">
      <%= f.submit "Zarejestruj",
            class: "w-full px-4 py-2 bg-indigo-600 text-white font-semibold rounded hover:bg-indigo-700" %>
    </div>
  <% end %>

  <div class="mt-6 pt-4 border-t border-gray-100">
    <%= render "devise/shared/links" %>
  </div>
</div>
