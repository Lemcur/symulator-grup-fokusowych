<div class="space-y-1 text-sm">
  <%- if controller_name != 'sessions' %>
    <p><%= link_to "Zaloguj się", new_session_path(resource_name), class: "text-indigo-600 hover:underline" %></p>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <p><%= link_to "Zarejestruj się", new_registration_path(resource_name), class: "text-indigo-600 hover:underline" %></p>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <p><%= link_to "Zapomniałeś hasła?", new_password_path(resource_name), class: "text-indigo-600 hover:underline" %></p>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <p><%= link_to "Nie dostałeś instrukcji potwierdzenia?", new_confirmation_path(resource_name), class: "text-indigo-600 hover:underline" %></p>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <p><%= link_to "Nie dostałeś instrukcji odblokowania?", new_unlock_path(resource_name), class: "text-indigo-600 hover:underline" %></p>
  <% end %>
</div>
