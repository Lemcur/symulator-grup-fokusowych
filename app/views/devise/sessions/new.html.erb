<% content_for :title, "Logowanie" %>

<div class="max-w-md mx-auto bg-white p-8 rounded shadow border border-gray-200 mt-12">
  <h1 class="text-2xl font-bold mb-6">Logowanie</h1>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
    <div>
      <%= f.label :email, class: "block font-semibold mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full px-3 py-2 border border-gray-300 rounded" %>
    </div>

    <div>
      <%= f.label :password, class: "block font-semibold mb-1" %>
      <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full px-3 py-2 border border-gray-300 rounded" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="flex items-center gap-2">
        <%= f.check_box :remember_me %>
        <%= f.label :remember_me, class: "text-sm text-gray-700" %>
      </div>
    <% end %>

    <div class="pt-2">
      <%= f.submit "Zaloguj",
            class: "w-full px-4 py-2 bg-indigo-600 text-white font-semibold rounded hover:bg-indigo-700" %>
    </div>
  <% end %>

  <div class="mt-6 pt-4 border-t border-gray-100">
    <%= render "devise/shared/links" %>
  </div>
</div>
