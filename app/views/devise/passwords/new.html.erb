<% content_for :title, "Reset hasła" %>

<div class="max-w-md mx-auto bg-white p-8 rounded shadow border border-gray-200 mt-12">
  <h1 class="text-2xl font-bold mb-6">Zapomniałeś hasła?</h1>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-4" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, class: "block font-semibold mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full px-3 py-2 border border-gray-300 rounded" %>
    </div>

    <div class="pt-2">
      <%= f.submit "Wyślij link resetujący",
            class: "w-full px-4 py-2 bg-indigo-600 text-white font-semibold rounded hover:bg-indigo-700" %>
    </div>
  <% end %>

  <div class="mt-6 pt-4 border-t border-gray-100">
    <%= render "devise/shared/links" %>
  </div>
</div>
