<% in_progress = !(focus_group.completed? || focus_group.failed?) %>

<div class="flex items-center justify-between mb-6">
  <span class="px-3 py-1 text-xs uppercase tracking-wide bg-indigo-100 text-indigo-800 rounded">
    <%= focus_group.status.humanize %>
  </span>
  <span class="text-xs text-gray-500">
    <%= in_progress ? "Aktualizacja co 3s" : "Zakończono #{focus_group.completed_at&.strftime('%H:%M')}" %>
  </span>
</div>

<% if in_progress %>
  <div class="mb-6 bg-white p-4 rounded shadow border border-gray-200">
    <% percent = (focus_group.progress * 100).round %>
    <% label = case focus_group.status
               when "pending", "generating_personas" then "Generowanie person"
               when "collecting_opinions"             then "Zbieranie opinii (round 0)"
               when "deliberating"                    then "Deliberacja (round 1)"
               when "synthesizing"                    then "Synteza rekomendacji"
               else focus_group.status.humanize
               end %>
    <div class="flex justify-between mb-2 text-sm">
      <span class="font-semibold"><%= label %></span>
      <span class="text-gray-600"><%= percent %>%</span>
    </div>
    <div class="w-full bg-gray-200 rounded h-2">
      <div class="bg-indigo-600 h-2 rounded transition-all duration-500" style="width: <%= percent %>%"></div>
    </div>
  </div>
<% end %>

<% if focus_group.recommendation %>
  <%= render "recommendation", recommendation: focus_group.recommendation %>
<% end %>

<% personas = focus_group.personas.order(:created_at) %>
<% if personas.any? %>
  <h2 class="text-xl font-semibold mb-3 mt-8">Persony (<%= personas.size %>)</h2>
  <div class="space-y-3">
    <% personas.each do |persona| %>
      <details class="bg-white rounded shadow border border-gray-200 group">
        <summary class="px-4 py-3 cursor-pointer flex items-center justify-between">
          <div>
            <span class="font-semibold"><%= persona.name %></span>
            <span class="text-sm text-gray-600 ml-2">
              <%= [persona.demographics["wiek"], persona.demographics["miasto"], persona.demographics["zawod"]].compact.join(" · ") %>
            </span>
          </div>
          <span class="text-xs text-gray-500"><%= persona.llm_model %></span>
        </summary>
        <div class="px-4 pb-4 space-y-3">
          <p class="text-sm text-gray-700 whitespace-pre-wrap"><%= persona.description %></p>

          <% [["round 0 — opinia prywatna", persona.round_zero_opinion],
              ["round 1 — po deliberacji",   persona.round_one_opinion]].each do |label, op| %>
            <% next unless op %>
            <div class="border-t border-gray-100 pt-3">
              <div class="flex items-center justify-between mb-2">
                <span class="text-xs uppercase tracking-wide text-gray-500"><%= label %></span>
                <span class="font-bold text-lg"><%= op.rating %>/5</span>
              </div>
              <% if op.revised %>
                <p class="text-xs text-amber-700 mb-2 italic">Zrewidowano: <%= op.revision_rationale %></p>
              <% end %>
              <p class="text-sm"><strong>Plusy:</strong> <%= op.pros %></p>
              <p class="text-sm"><strong>Minusy:</strong> <%= op.cons %></p>
              <p class="text-sm italic mt-1">„<%= op.quote %>"</p>
            </div>
          <% end %>
        </div>
      </details>
    <% end %>
  </div>
<% end %>
