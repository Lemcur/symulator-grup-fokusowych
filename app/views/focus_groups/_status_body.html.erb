<% awaiting   = focus_group.awaiting_review? %>
<% terminal  = focus_group.completed? || focus_group.failed? %>
<% polling   = !(terminal || awaiting) %>
<% in_progress_bar = !(terminal || awaiting) %>

<% unless polling %>
  <span data-poll-done="true" hidden></span>
<% end %>

<div class="flex items-center justify-between mb-6">
  <span class="px-3 py-1 text-xs uppercase tracking-wide bg-indigo-100 text-indigo-800 rounded">
    <%= focus_group.status.humanize %>
  </span>
  <span class="text-xs text-gray-500">
    <% if terminal %>
      Zakończono <%= focus_group.completed_at&.strftime('%H:%M') %>
    <% elsif awaiting %>
      Oczekuje na zatwierdzenie person
    <% else %>
      Aktualizacja co 3s
    <% end %>
  </span>
</div>

<% if awaiting %>
  <div class="mb-6 bg-amber-50 border border-amber-300 rounded p-4 flex items-center justify-between gap-4">
    <div class="text-sm text-amber-900">
      <p class="font-semibold mb-1">Persony gotowe do przeglądu</p>
      <p>Przejrzyj listę poniżej. Możesz usunąć, edytować lub dodać persony. Gdy lista będzie OK, kliknij „Zatwierdź".</p>
    </div>
    <div class="flex gap-2 shrink-0">
      <%= link_to "Dodaj personę",
            new_focus_group_persona_path(focus_group),
            class: "px-3 py-2 bg-white border border-amber-400 text-amber-900 rounded hover:bg-amber-100 text-sm font-semibold",
            data: { turbo_frame: "_top" } %>
      <%= button_to "Zatwierdź i rozpocznij",
            approve_focus_group_path(focus_group),
            method: :post,
            class: "px-3 py-2 bg-indigo-600 text-white rounded hover:bg-indigo-700 text-sm font-semibold",
            data: { turbo_frame: "_top" } %>
    </div>
  </div>
<% end %>

<% if in_progress_bar %>
  <div class="mb-6 bg-white p-4 rounded shadow border border-gray-200">
    <% percent = (focus_group.progress * 100).round %>
    <% label = case focus_group.status
               when "pending", "generating_personas" then "Generowanie person"
               when "collecting_opinions"             then "Zbieranie opinii (round 0)"
               when "deliberating"                    then "Deliberacja (round 1)"
               when "synthesizing"                    then "Synteza rekomendacji"
               else focus_group.status.humanize
               end %>
    <div class="flex justify-between mb-2 text-sm">
      <span class="font-semibold"><%= label %></span>
      <span class="text-gray-600"><%= percent %>%</span>
    </div>
    <div class="w-full bg-gray-200 rounded h-2">
      <div class="bg-indigo-600 h-2 rounded transition-all duration-500" style="width: <%= percent %>%"></div>
    </div>
  </div>
<% end %>

<% if focus_group.recommendation %>
  <%= render "recommendation", recommendation: focus_group.recommendation %>
<% end %>

<% personas = focus_group.personas.order(:created_at) %>
<% if personas.any? %>
  <h2 class="text-xl font-semibold mb-3 mt-8">Persony (<%= personas.size %>)</h2>
  <div class="space-y-3">
    <% personas.each do |persona| %>
      <details class="bg-white rounded shadow border border-gray-200 group">
        <summary class="px-4 py-3 cursor-pointer flex items-center justify-between gap-3">
          <div class="min-w-0">
            <span class="font-semibold"><%= persona.name %></span>
            <span class="text-sm text-gray-600 ml-2">
              <%= [persona.demographics&.dig("wiek"), persona.demographics&.dig("miasto"), persona.demographics&.dig("zawod")].compact.join(" · ") %>
            </span>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <span class="text-xs text-gray-500"><%= persona.llm_model %></span>
            <% if awaiting %>
              <%= link_to "Edytuj",
                    edit_focus_group_persona_path(focus_group, persona),
                    class: "px-2 py-1 text-xs bg-gray-100 border border-gray-300 rounded hover:bg-gray-200",
                    data: { turbo_frame: "_top" } %>
              <% confirm_msg = "Usunąć personę „#{persona.name}”?" %>
              <%= button_to "Usuń",
                    focus_group_persona_path(focus_group, persona),
                    method: :delete,
                    form: { data: { turbo_confirm: confirm_msg, turbo_frame: "_top" } },
                    class: "px-2 py-1 text-xs bg-red-50 border border-red-300 text-red-800 rounded hover:bg-red-100" %>
            <% end %>
          </div>
        </summary>
        <div class="px-4 pb-4 space-y-3">
          <p class="text-sm text-gray-700 whitespace-pre-wrap"><%= persona.description %></p>

          <% [["round 0 — opinia prywatna", persona.round_zero_opinion],
              ["round 1 — po deliberacji",   persona.round_one_opinion]].each do |label, op| %>
            <% next unless op %>
            <div class="border-t border-gray-100 pt-3">
              <div class="flex items-center justify-between mb-2">
                <span class="text-xs uppercase tracking-wide text-gray-500"><%= label %></span>
                <span class="font-bold text-lg"><%= op.rating %>/5</span>
              </div>
              <% if op.revised %>
                <p class="text-xs text-amber-700 mb-2 italic">Zrewidowano: <%= op.revision_rationale %></p>
              <% end %>
              <p class="text-sm"><strong>Plusy:</strong> <%= op.pros %></p>
              <p class="text-sm"><strong>Minusy:</strong> <%= op.cons %></p>
              <p class="text-sm italic mt-1">„<%= op.quote %>"</p>
            </div>
          <% end %>
        </div>
      </details>
    <% end %>
  </div>
<% end %>
