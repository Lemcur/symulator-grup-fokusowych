<% content_for :title, "Nowa sesja fokusowa" %>

<h1 class="text-2xl font-bold mb-6">Nowa sesja fokusowa</h1>

<% if @products.empty? %>
  <div class="bg-yellow-50 border border-yellow-300 text-yellow-900 p-4 rounded">
    Najpierw musisz utworzyć produkt. <%= link_to "Dodaj produkt", new_product_path, class: "underline font-semibold" %>.
  </div>
<% else %>
  <div class="max-w-3xl bg-white p-6 rounded shadow border border-gray-200">
    <%= form_with model: @focus_group, class: "space-y-4" do |f| %>
      <% if @focus_group.errors.any? %>
        <div class="px-4 py-2 bg-red-100 border border-red-300 text-red-900 rounded">
          <p class="font-semibold mb-1"><%= pluralize(@focus_group.errors.count, "błąd") %>:</p>
          <ul class="list-disc list-inside text-sm">
            <% @focus_group.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :name, "Nazwa sesji", class: "block font-semibold mb-1" %>
        <%= f.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded",
              placeholder: "Pilot - kobiety 25-34, miasta" %>
      </div>

      <div>
        <%= f.label :product_id, "Produkt", class: "block font-semibold mb-1" %>
        <%= f.collection_select :product_id, @products, :id, :name,
              { prompt: "- wybierz produkt -" },
              class: "w-full px-3 py-2 border border-gray-300 rounded" %>
      </div>

      <div>
        <%= f.label :sample_size, "Wielkość próby (N)", class: "block font-semibold mb-1" %>
        <%= f.number_field :sample_size, min: 1, max: 50,
              class: "w-full px-3 py-2 border border-gray-300 rounded" %>
        <p class="text-xs text-gray-500 mt-1">Zalecane: 12 (cost vs. variance).</p>
      </div>

      <div>
        <%= f.label :persona_generator, "Generator person", class: "block font-semibold mb-1" %>
        <%= f.select :persona_generator,
              FocusGroup.persona_generators.keys.map { |k| [k.humanize, k] },
              {},
              class: "w-full px-3 py-2 border border-gray-300 rounded" %>
      </div>

      <div class="flex items-start gap-2 bg-amber-50 border border-amber-200 rounded p-3">
        <%= f.check_box :require_persona_review, class: "mt-1" %>
        <div>
          <%= f.label :require_persona_review, "Przejrzyj persony przed dyskusją", class: "font-semibold" %>
          <p class="text-xs text-gray-600">
            Po wygenerowaniu sesja zatrzyma się - będziesz mógł usunąć, edytować lub dodać persony przed zbieraniem opinii.
          </p>
        </div>
      </div>

      <% has_json = @focus_group.target_demographics.present? && @focus_group.target_demographics != {} %>
      <% initial_mode = has_json ? "json" : "brief" %>

      <div data-controller="spec-toggle" data-spec-toggle-mode-value="<%= initial_mode %>">
        <label class="block font-semibold mb-2">Specyfikacja grupy</label>
        <div class="flex gap-4 mb-3 text-sm">
          <label class="flex items-center gap-2">
            <input type="radio" name="spec_mode" value="brief"
                   <%= "checked" if initial_mode == "brief" %>
                   data-action="spec-toggle#switch"
                   data-spec-toggle-target="radio">
            <span>Opis tekstowy</span>
          </label>
          <label class="flex items-center gap-2">
            <input type="radio" name="spec_mode" value="json"
                   <%= "checked" if initial_mode == "json" %>
                   data-action="spec-toggle#switch"
                   data-spec-toggle-target="radio">
            <span>Zaawansowane (JSON)</span>
          </label>
        </div>

        <div data-spec-toggle-target="brief" class="<%= "hidden" if initial_mode != "brief" %>">
          <%= f.text_area :brief_summary,
                rows: 6,
                placeholder: "Np. Kobiety 25-34 z dużych polskich miast, raczej z wyższym wykształceniem, zainteresowane nauką języków obcych. Pracujące zawodowo, zarobki średnie i wyższe.",
                class: "w-full px-3 py-2 border border-gray-300 rounded" %>
          <p class="text-xs text-gray-500 mt-1">
            Opisz docelową grupę swobodnym tekstem - LLM uzupełni demografię.
          </p>
        </div>

        <div data-spec-toggle-target="json" class="<%= "hidden" if initial_mode != "json" %>">
          <%= f.text_area :target_demographics,
                value: (@focus_group.target_demographics.is_a?(String) ? @focus_group.target_demographics : JSON.pretty_generate(@focus_group.target_demographics || {})),
                rows: 10,
                class: "w-full px-3 py-2 border border-gray-300 rounded font-mono text-sm" %>
          <p class="text-xs text-gray-500 mt-1">
            Hash rozkładów: <code>{"wiek": {"25-29": 0.5, ...}, ...}</code>;
            tablica slotów: <code>[{"count": 5, "wiek": "25-29", ...}, ...]</code>.
          </p>
        </div>
      </div>

      <div class="flex gap-2 pt-2">
        <%= f.submit "Utwórz i uruchom",
              class: "px-4 py-2 bg-indigo-600 text-white rounded hover:bg-indigo-700" %>
        <%= link_to "Anuluj", focus_groups_path,
              class: "px-4 py-2 bg-gray-200 text-gray-800 rounded hover:bg-gray-300" %>
      </div>
    <% end %>
  </div>
<% end %>
