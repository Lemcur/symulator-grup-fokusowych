<% content_for :title, @focus_group.name %>

<div class="flex items-start justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold"><%= @focus_group.name %></h1>
    <p class="text-gray-600">
      <%= link_to @focus_group.product.name, @focus_group.product, class: "text-indigo-700 hover:underline" %>
      · N=<%= @focus_group.sample_size %>
    </p>
  </div>
</div>

<%= render "status", focus_group: @focus_group %>
