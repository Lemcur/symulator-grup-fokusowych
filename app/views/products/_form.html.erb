<%= form_with model: product, multipart: true, class: "space-y-4" do |f| %>
  <% if product.errors.any? %>
    <div class="px-4 py-2 bg-red-100 border border-red-300 text-red-900 rounded">
      <p class="font-semibold mb-1"><%= pluralize(product.errors.count, "błąd") %>:</p>
      <ul class="list-disc list-inside text-sm">
        <% product.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Nazwa", class: "block font-semibold mb-1" %>
    <%= f.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded" %>
  </div>

  <div>
    <%= f.label :description, "Opis", class: "block font-semibold mb-1" %>
    <%= f.text_area :description, rows: 6, class: "w-full px-3 py-2 border border-gray-300 rounded" %>
  </div>

  <% attached_count = product.images.attached? ? product.images.count : 0 %>

  <div data-controller="image-picker"
       data-image-picker-attached-value="<%= attached_count %>"
       data-image-picker-max-value="<%= Product::MAX_IMAGES %>"
       data-image-picker-max-bytes-value="<%= Product::MAX_IMAGE_SIZE %>">
    <div class="flex items-baseline justify-between mb-1">
      <%= f.label :images, "Zdjęcia produktu", class: "block font-semibold" %>
      <span class="text-xs text-gray-500" data-image-picker-target="counter">
        <%= attached_count %>/<%= Product::MAX_IMAGES %> zdjęć
      </span>
    </div>

    <% if product.persisted? && product.images.attached? %>
      <div class="grid grid-cols-3 gap-3 mb-3">
        <% product.images.each do |image| %>
          <div class="relative border border-gray-200 rounded overflow-hidden">
            <%= image_tag image.representation(resize_to_limit: [240, 240]),
                  class: "w-full h-32 object-cover" %>
            <%= link_to "Usuń",
                  product_image_path(product, image.signed_id),
                  data: { turbo_method: :delete, turbo_confirm: "Usunąć to zdjęcie?" },
                  class: "absolute top-1 right-1 px-2 py-1 text-xs bg-red-600 text-white rounded hover:bg-red-700 no-underline" %>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="grid grid-cols-3 gap-3 mb-3" data-image-picker-target="previews"></div>

    <%= f.file_field :images,
          multiple: true,
          accept: Product::ALLOWED_IMAGE_TYPES.join(","),
          data: { image_picker_target: "input", action: "change->image-picker#inputChanged" },
          class: "block w-full text-sm text-gray-700 file:mr-3 file:px-3 file:py-2 file:border-0 file:rounded file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>

    <p class="text-xs text-gray-500 mt-1" data-image-picker-target="remaining">
      Możesz dodać jeszcze <%= Product::MAX_IMAGES - attached_count %>.
    </p>
    <p class="text-xs mt-1">
      PNG, JPEG, WEBP lub GIF. Maks. <%= Product::MAX_IMAGE_SIZE / 1.megabyte %> MB na plik.
    </p>
    <p class="hidden text-sm text-red-700 mt-2 px-3 py-2 bg-red-50 border border-red-200 rounded"
       data-image-picker-target="warning"></p>
  </div>

  <div class="flex gap-2">
    <%= f.submit class: "px-4 py-2 bg-indigo-600 text-white rounded hover:bg-indigo-700" %>
    <%= link_to "Anuluj", products_path, class: "px-4 py-2 bg-gray-200 text-gray-800 rounded hover:bg-gray-300" %>
  </div>
<% end %>
