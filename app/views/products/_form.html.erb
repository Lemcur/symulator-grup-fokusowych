<%= form_with model: product, class: "space-y-4" do |f| %>
  <% if product.errors.any? %>
    <div class="px-4 py-2 bg-red-100 border border-red-300 text-red-900 rounded">
      <p class="font-semibold mb-1"><%= pluralize(product.errors.count, "błąd") %>:</p>
      <ul class="list-disc list-inside text-sm">
        <% product.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Nazwa", class: "block font-semibold mb-1" %>
    <%= f.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded" %>
  </div>

  <div>
    <%= f.label :description, "Opis", class: "block font-semibold mb-1" %>
    <%= f.text_area :description, rows: 6, class: "w-full px-3 py-2 border border-gray-300 rounded" %>
  </div>

  <div class="flex gap-2">
    <%= f.submit class: "px-4 py-2 bg-indigo-600 text-white rounded hover:bg-indigo-700" %>
    <%= link_to "Anuluj", products_path, class: "px-4 py-2 bg-gray-200 text-gray-800 rounded hover:bg-gray-300" %>
  </div>
<% end %>
