<% content_for :title, @product.name %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold"><%= @product.name %></h1>
  <div class="flex gap-2">
    <%= link_to "Edytuj", edit_product_path(@product),
          class: "px-3 py-2 bg-gray-200 text-gray-800 rounded hover:bg-gray-300" %>
    <%= button_to "Usuń", @product, method: :delete,
          form: { data: { turbo_confirm: "Na pewno usunąć ten produkt i wszystkie jego sesje?" } },
          class: "px-3 py-2 bg-red-600 text-white rounded hover:bg-red-700" %>
  </div>
</div>

<div class="bg-white p-6 rounded shadow border border-gray-200 mb-6">
  <p class="whitespace-pre-wrap"><%= @product.description %></p>

  <% if @product.images.attached? %>
    <div class="grid grid-cols-3 gap-3 mt-6">
      <% @product.images.each do |image| %>
        <%= image_tag image.representation(resize_to_limit: [400, 400]),
              class: "w-full h-40 object-cover rounded border border-gray-200" %>
      <% end %>
    </div>
  <% end %>
</div>

<h2 class="text-xl font-semibold mb-3">Sesje fokusowe dla tego produktu</h2>
<% sessions = @product.focus_groups.order(created_at: :desc) %>
<% if sessions.empty? %>
  <p class="text-gray-600">Brak sesji. <%= link_to "Utwórz nową", new_focus_group_path, class: "text-indigo-700 underline" %>.</p>
<% else %>
  <ul class="bg-white rounded shadow border border-gray-200 divide-y divide-gray-100">
    <% sessions.each do |fg| %>
      <li class="px-4 py-3 flex items-center justify-between">
        <%= link_to fg.name, fg, class: "text-indigo-700 hover:underline" %>
        <span class="text-xs uppercase tracking-wide text-gray-500"><%= fg.status.humanize %></span>
      </li>
    <% end %>
  </ul>
<% end %>
