<%= form_with model: [focus_group, persona], class: "space-y-4" do |f| %>
  <% if persona.errors.any? %>
    <div class="px-4 py-2 bg-red-100 border border-red-300 text-red-900 rounded">
      <p class="font-semibold mb-1"><%= pluralize(persona.errors.count, "błąd") %>:</p>
      <ul class="list-disc list-inside text-sm">
        <% persona.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Imię i nazwisko", class: "block font-semibold mb-1" %>
    <%= f.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded" %>
  </div>

  <div>
    <%= f.label :description, "Opis", class: "block font-semibold mb-1" %>
    <%= f.text_area :description, rows: 5, class: "w-full px-3 py-2 border border-gray-300 rounded" %>
  </div>

  <div>
    <%= f.label :demographics, "Demographics (JSON)", class: "block font-semibold mb-1" %>
    <%= f.text_area :demographics,
          value: JSON.pretty_generate(persona.demographics || {}),
          rows: 6,
          class: "w-full px-3 py-2 border border-gray-300 rounded font-mono text-sm" %>
  </div>

  <div>
    <%= f.label :traits, "Traits (JSON)", class: "block font-semibold mb-1" %>
    <%= f.text_area :traits,
          value: JSON.pretty_generate(persona.traits || {}),
          rows: 8,
          class: "w-full px-3 py-2 border border-gray-300 rounded font-mono text-sm" %>
  </div>

  <div class="flex gap-2 pt-2">
    <%= f.submit class: "px-4 py-2 bg-indigo-600 text-white rounded hover:bg-indigo-700" %>
    <%= link_to "Anuluj", focus_group, class: "px-4 py-2 bg-gray-200 text-gray-800 rounded hover:bg-gray-300" %>
  </div>
<% end %>
