@startuml SequenceDiagram_MultipleRound_SetupAndPairing
title Sequence Diagram - Multiple-Round: tworzenie sesji, generowanie Person, parowanie do dyskusji

skinparam responseMessageBelowArrow true
skinparam sequenceMessageAlign center

actor User
participant "FocusGroupsController" as Ctrl
participant "GeneratePersonaJob" as Job <<asynchronous>>
participant "PersonaPairingService" as Pair
database "DB" as DB
participant "LLM API" as LLM <<external>>

== 1. Tworzenie sesji (synchronicznie) ==

User -> Ctrl : POST /focus_groups\n(product_id, seed_descriptions[])
activate Ctrl
Ctrl -> DB : save FocusGroup(status = pending)
DB --> Ctrl : focus_group

loop dla każdego seed_description z formularza
  Ctrl -> DB : save Persona(focus_group, seed_description)
  DB --> Ctrl : persona
  Ctrl -> Job : dodaj do kolejki GeneratePersonaJob(persona.id)
end

Ctrl -> DB : update FocusGroup.status = generating_personas
Ctrl --> User : redirect na widok statusu sesji
deactivate Ctrl

note over User
  Od tej chwili User obserwuje widok statusu;
  cały dalszy przebieg dzieje się automatycznie
  w tle, bez interakcji użytkownika.
end note

== 2. Generowanie Person (równolegle, w tle) ==

note over Job
  N jobów wykonywanych niezależnie i równolegle.
  Poniżej przepływ pojedynczego.
end note

activate Job
Job -> DB : load Persona(id)
DB --> Job : persona (z seed_description)

Job -> LLM : prompt: rozbuduj seed_description\n→ name, description, demographics,\ntraits, pairing_tags, system_prompt
LLM --> Job : profil persony (JSON)

Job -> DB : update Persona polami profilu
DB --> Job : ok

Job ->> User : aktualizacja postępu: "k / N person gotowych"

Job -> DB : all_personas_generated?
DB --> Job : tak / nie

opt to ostatnia Persona z sesji
  Job -> DB : update FocusGroup.status = pairing
  Job ->> User : aktualizacja statusu: "parowanie person..."

  Job -> Pair : call(focus_group)
  activate Pair
  Pair -> DB : load wszystkie Persony sesji
  DB --> Pair : personas

  note right of Pair
    Algorytm dobiera rozmiar grupy (preferuje 3)
    i grupuje Persony, minimalizując powtórzenia
    wartości pairing_tags w obrębie grupy.
  end note

  loop dla każdej obliczonej grupy
    Pair -> DB : save Discussion + przypisz Persony grupy
    DB --> Pair : discussion
  end
  Pair --> Job : discussions
  deactivate Pair

  Job -> DB : update FocusGroup.status = discussions_running

  loop dla każdej Discussion
    Job -> Job : dodaj do kolejki\nRunTurnJob(discussion.id, first_persona.id)
  end
  Job ->> User : aktualizacja statusu: "rozpoczynam dyskusje..."
end
deactivate Job

note over User
  Faza dyskusji startuje automatycznie
  (Diagram 2: przebieg jednej dyskusji).
  User pozostaje na widoku statusu, bez akcji.
end note

@enduml
